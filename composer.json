{
    "name": "cds-uwb/php-code-style",
    "description": "CDS team PHP coding style for PHP-CS-Fixer",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "files": [
            "src/rules.php"
        ]
    },
    "minimum-stability": "stable",
    "php": ">=8.4",
    "scripts": {
        "phpunit": "phpunit -c phpunit.xml --coverage-text --coverage-clover=coverage.xml"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    }
}
